{
  "name": "postcss-advanced-variables-plus",
  "version": "1.2.0",
  "description": "Use Sass-like variables, conditionals, and iterators in CSS — a modernised TypeScript fork of postcss-advanced-variables",
  "author": "Daniel Baars",
  "license": "CC0-1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielbaars/postcss-advanced-variables-plus.git"
  },
  "homepage": "https://github.com/danielbaars/postcss-advanced-variables-plus#readme",
  "bugs": "https://github.com/danielbaars/postcss-advanced-variables-plus/issues",
  "type": "module",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "postcss": "^8.4"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "postcss": "^8.4",
    "postcss-scss": "^4.0.9",
    "tsdown": "^0.12.0",
    "typescript": "^5.8",
    "vitest": "^3.0"
  }
}
